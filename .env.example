# Your EOA private key (with or without 0x prefix)
PRIVATE_KEY=0x...

# Option A: Relayer API Key (get from polymarket.com/settings > API Keys)
POLY_RELAYER_API_KEY=your_relayer_api_key
POLY_RELAYER_ADDRESS=0x...your_safe_or_proxy_address

# Option B: Builder API Key (for Builder Program members)
# POLY_BUILDER_API_KEY=your_builder_api_key
# POLY_BUILDER_SECRET=your_base64_encoded_secret
# POLY_BUILDER_PASSPHRASE=your_passphrase
