# Your EOA private key (with or without 0x prefix)
PRIVATE_KEY=0x...

# Your wallet address on Polygon (Safe or Proxy)
POLY_RELAYER_ADDRESS=0x...

# ── Wallet type ─────────────────────────────────────────────────────
# Polymarket signature_type:
#   0 = EOA       (direct wallet, no contract abstraction)
#   1 = Proxy     (magic.link proxy wallet)
#   2 = Safe      (Gnosis Safe wallet, default)
SIGNATURE_TYPE=2

# ── Auth (pick one) ──────────────────────────────────────────────────

# Option A: Builder API Key (recommended — enables gasless mode)
BUILDER_KEY=your_builder_api_key
BUILDER_SECRET=your_base64_encoded_secret
BUILDER_PASSPHRASE=your_passphrase

# Option B: Relayer API Key (get from polymarket.com/settings > API Keys)
# POLY_RELAYER_API_KEY=your_relayer_api_key

# ── Direct fallback (when relayer returns 429) ───────────────────────
# WARNING: Do NOT use https://polygon-rpc.com — it has TLS issues.
# Use Alchemy, QuickNode, or LlamaRPC instead.

# Polygon RPC URL (needs MATIC in your EOA for gas)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
